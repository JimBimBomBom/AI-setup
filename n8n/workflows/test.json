{
  "id": "test-workflow-manual",
  "name": "Test Job - Manual",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "notes": "Click 'Execute Workflow' to manually trigger test job"
    },
    {
      "parameters": {
        "jsCode": "// Load TEST job configuration\nconst JOB_NAME = 'test';\n\nconst fs = require('fs');\nconst path = `/data/jobs/${JOB_NAME}.json`;\n\ntry {\n  const configData = fs.readFileSync(path, 'utf8');\n  const config = JSON.parse(configData);\n  \n  // Return one item per source\n  const items = config.sources.map(source => ({\n    json: {\n      config: config,\n      source: source,\n      jobName: JOB_NAME\n    }\n  }));\n  \n  return items;\n} catch (error) {\n  throw new Error(`Could not read job config at ${path}: ${error.message}`);\n}"
      },
      "id": "load-config",
      "name": "Load Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "url": "={{ $json.source.url }}",
        "options": {
          "split": false
        }
      },
      "id": "fetch-rss",
      "name": "Fetch RSS",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1,
      "position": [650, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Filter articles by lookback_hours and process\nconst items = $input.all();\nconst now = new Date();\nconst lookbackHours = items[0]?.json?.config?.lookback_hours || 24;\nconst maxAgeMs = lookbackHours * 60 * 60 * 1000;\n\nconst allArticles = [];\n\nfor (const item of items) {\n  if (!item.json.items) continue;\n  \n  const config = item.json.config;\n  const source = item.json.source;\n  \n  for (const article of item.json.items) {\n    const pubDate = new Date(article.pubDate || article.isoDate || Date.now());\n    const ageMs = now - pubDate;\n    \n    if (ageMs <= maxAgeMs) {\n      allArticles.push({\n        json: {\n          title: article.title || 'Untitled',\n          description: article.contentSnippet || article.content || article.summary || '',\n          link: article.link || article.guid || '',\n          pubDate: pubDate.toISOString(),\n          source: source.name,\n          category: source.category\n        }\n      });\n    }\n  }\n}\n\n// Limit to max_articles\nconst maxArticles = items[0]?.json?.config?.max_articles || 60;\nreturn allArticles.slice(0, maxArticles);"
      },
      "id": "filter-articles",
      "name": "Filter Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "articles",
        "options": {}
      },
      "id": "aggregate-articles",
      "name": "Aggregate Articles",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "jsCode": "// Build the prompt for Ollama\nconst items = $input.all();\nif (items.length === 0 || !items[0].json.articles || items[0].json.articles.length === 0) {\n  return [];\n}\n\nconst config = items[0].json.config;\nconst articles = items[0].json.articles;\n\n// Group articles by category\nconst byCategory = {};\nfor (const article of articles) {\n  const cat = article.json.category || 'general';\n  if (!byCategory[cat]) byCategory[cat] = [];\n  byCategory[cat].push(article.json);\n}\n\n// Build article list\nlet articleList = '';\nfor (const [category, catArticles] of Object.entries(byCategory)) {\n  articleList += `\\n## ${category.toUpperCase()}\\n`;\n  for (const article of catArticles) {\n    articleList += `- **${article.title}** (${article.source}): ${article.description.substring(0, 200)}\\n`;\n  }\n}\n\nconst userPrompt = config.user_prompt_format || 'Summarize these news articles:';\n\nreturn [{\n  json: {\n    config: config,\n    systemPrompt: config.system_prompt || 'You are a news summarizer.',\n    userPrompt: userPrompt + articleList,\n    articleCount: articles.length\n  }\n}];"
      },
      "id": "build-prompt",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "2a5b6cc6-23a5-4f1c-a2e3-4be9f5ce3b2f",
              "leftValue": "={{ $json.articleCount }}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-articles",
      "name": "Have Articles?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1450, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.config.ollama_url || 'http://host.docker.internal:11434/api/chat' }}",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "model": "={{ $json.config.model }}",
          "messages": [
            {
              "role": "system",
              "content": "={{ $json.systemPrompt }}"
            },
            {
              "role": "user",
              "content": "={{ $json.userPrompt }}"
            }
          ],
          "stream": false,
          "options": "={{ $json.config.ollama_options || {} }}"
        },
        "options": {}
      },
      "id": "ollama-summarize",
      "name": "Ollama Summarize",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 200]
    },
    {
      "parameters": {
        "jsCode": "// Format for Discord with env var fallback\nconst items = $input.all();\nconst httpResponse = items[0]?.json;\n\n// Extract summary from Ollama HTTP response (message.content)\nlet summary = 'No summary generated.';\nif (httpResponse?.message?.content) {\n  summary = httpResponse.message.content;\n} else if (typeof httpResponse?.message === 'string') {\n  summary = httpResponse.message;\n} else if (httpResponse?.response) {\n  summary = httpResponse.response;\n}\n\n// Get config from the Build Prompt node output (passed through HTTP Request)\n// We need to get it from the previous node output\nconst allItems = $input.all();\nconst config = allItems[0]?.json?._config || allItems[0]?.json?.config;"\n\nconst title = config?.name || 'News Digest';\nconst today = new Date().toISOString().split('T')[0];\n\n// Get webhook URL - check config first, then env var, then empty\nlet webhookUrl = config?.discord?.webhook_url || '';\nconst webhookEnvVar = config?.discord?.webhook_url_env;\n\n// If no webhook in config but env var name specified, try to get from env\nif (!webhookUrl && webhookEnvVar && process.env[webhookEnvVar]) {\n  webhookUrl = process.env[webhookEnvVar];\n}\n\n// Also try TEST_DISCORD_WEBHOOK_URL as fallback for test jobs\nif (!webhookUrl && process.env.TEST_DISCORD_WEBHOOK_URL) {\n  webhookUrl = process.env.TEST_DISCORD_WEBHOOK_URL;\n}\n\n// Split into chunks if needed (Discord limit is 4096)\nconst MAX_LENGTH = 4000;\nconst chunks = [];\n\nif (summary.length <= MAX_LENGTH) {\n  chunks.push(summary);\n} else {\n  const parts = summary.split('\\n\\n');\n  let current = '';\n  for (const part of parts) {\n    if ((current + part).length > MAX_LENGTH) {\n      if (current) chunks.push(current.trim());\n      current = part;\n    } else {\n      current += '\\n\\n' + part;\n    }\n  }\n  if (current) chunks.push(current.trim());\n}\n\nconst embeds = chunks.map((chunk, i) => ({\n  title: i === 0 ? `${title} - ${today}` : `${title} (cont.)`,\n  description: chunk,\n  color: config?.discord?.embed_color || 3447003,\n  footer: {\n    text: i === chunks.length - 1 ? `Generated by ${config?.model || 'Ollama'}` : `Part ${i + 1}/${chunks.length}`\n  }\n}));\n\n// If no webhook URL, return empty to skip Discord sending gracefully\nif (!webhookUrl) {\n  return [{\n    json: {\n      skipDiscord: true,\n      reason: 'No Discord webhook configured. Set webhook_url in job config or TEST_DISCORD_WEBHOOK_URL in .env',\n      summary: summary\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    webhookUrl: webhookUrl,\n    username: config?.discord?.username || 'Test News Bot',\n    embeds: embeds,\n    skipDiscord: false\n  }\n}];"
      },
      "id": "format-discord",
      "name": "Format Discord",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1850, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-skip",
              "leftValue": "={{ $json.skipDiscord }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "notEqual"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-send-discord",
      "name": "Send to Discord?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2050, 200]
    },
    {
      "parameters": {
        "sendType": "json",
        "url": "={{ $json.webhookUrl }}",
        "options": {
          "bodyContentType": "json"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "username",
              "value": "={{ $json.username }}"
            },
            {
              "name": "embeds",
              "value": "={{ JSON.stringify($json.embeds) }}"
            }
          ]
        }
      },
      "id": "send-discord",
      "name": "Send to Discord",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2250, 200]
    },
    {
      "parameters": {
        "jsCode": "// Log that we're skipping Discord\nconst items = $input.all();\nconst item = items[0]?.json;\n\nif (item?.skipDiscord) {\n  console.log('Skipping Discord:', item.reason);\n  return [{\n    json: {\n      message: 'Discord sending skipped',\n      reason: item.reason,\n      summary: item.summary\n    }\n  }];\n}\n\nreturn [];"
      },
      "id": "log-skip",
      "name": "Log Skip",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2250, 400]
    },
    {
      "parameters": {},
      "id": "no-articles",
      "name": "No Articles (Skip)",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1650, 400]
    }
  ],
  "pinData": {},
