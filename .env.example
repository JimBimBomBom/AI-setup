# Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ==========================
# n8n Authentication
# ==========================
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here

# Encryption key for credentials (generate with: openssl rand -hex 16)
N8N_ENCRYPTION_KEY=your_encryption_key_here

# ==========================
# Timezone Configuration
# ==========================
# Set your timezone for cron scheduling
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Oslo

# ==========================
# Ollama Connection
# ==========================
# For Docker Desktop (Windows/Mac): use host.docker.internal
# For Linux with host network mode: use localhost
# For separate Ollama host: use the IP address
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434

# ==========================
# Email Configuration (SMTP)
# ==========================
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_SSL=true

# Generic SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SSL=true

# ==========================
# Discord Configuration
# ==========================
# Create a webhook in your Discord server:
# Server Settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ==========================
# Test Discord Webhook
# ==========================
# Optional: Separate webhook for testing the news digest workflow manually
# If set, the test.json job will use this instead of the production webhook
# Leave empty to skip Discord sending during tests
TEST_DISCORD_WEBHOOK_URL=

# ==========================
# Webhook URL (optional)
# ==========================
# If exposing n8n externally, set the full URL
WEBHOOK_URL=http://localhost:5678/
