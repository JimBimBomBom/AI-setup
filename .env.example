# Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ==========================
# n8n Authentication (REQUIRED)
# ==========================
N8N_USER=admin
N8N_PASSWORD=change_me_to_secure_password

# Encryption key for credentials (generate with: openssl rand -hex 16)
# This is REQUIRED for n8n to store credentials securely
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_16

# ==========================
# n8n Security (Local/LAN Setup)
# ==========================
# Disable secure cookies for local/LAN access (not using HTTPS)
N8N_SECURE_COOKIE=false

# ==========================
# Timezone Configuration (REQUIRED)
# ==========================
# Set your timezone for cron scheduling
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Oslo

# ==========================
# Ollama Connection (Auto-configured)
# ==========================
# These are set automatically via compose file
# OLLAMA_HOST=host.docker.internal
# OLLAMA_PORT=11434

# ==========================
# Discord Webhooks (REQUIRED for notifications)
# ==========================

# Production Discord Webhook (for world-news and tech-digest)
# Create at: Discord Server Settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Test Discord Webhook (for test and cron-test jobs)
# Optional: Can be same as above or a separate test channel
TEST_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_TEST_WEBHOOK_ID/YOUR_TEST_WEBHOOK_TOKEN

# ==========================
# Email Configuration (Optional)
# ==========================
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_SSL=true

# Generic SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SSL=true

# ==========================
# n8n API (Optional - for external access)
# ==========================
# If exposing n8n externally, set the full URL
WEBHOOK_URL=http://localhost:5678/
